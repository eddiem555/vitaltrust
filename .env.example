# VitalTrust environment variables (used by DeployVitalTrust.sh via Docker --env-file).
# Do NOT wrap values in quotes — Docker passes quotes literally and breaks auth/API keys.
# Format: KEY=value

# Cisco Duo OIDC Configuration
DUO_ISSUER_URL=
DUO_CLIENT_ID=
DUO_CLIENT_SECRET=

# AI & API Keys
GEMINI_API_KEY=
OPENAI_API_KEY=
GROQ_API_KEY=
CISCO_AI_DEFENSE_API_KEY=

# AWS Bedrock (optional — used when Bedrock model selected in AI Settings)
AWS_REGION=
AWS_ACCESS_KEY=
AWS_SECRET_KEY=

# Local user default password — SHA-256 hex digest (no salt). Required for local login.
# Example: echo -n 'YourLabPassword' | shasum -a 256
DEFAULT_PASSWORD_SHA256=

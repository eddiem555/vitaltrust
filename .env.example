# Vital Trust environment variables (used by DeployVitalTrust.sh via Docker --env-file)
# Do NOT wrap values in quotes — Docker passes quotes literally and quotes will break auth/API keys
# Format: KEY=value

# Cisco Duo OIDC Configuration
DUO_ISSUER_URL=
DUO_CLIENT_ID=
DUO_CLIENT_SECRET=

# Local user default password — SHA-256 hex digest (no salt).
# Option A: set DEFAULT_PASSWORD_SHA256 in .env before deploy (see hash commands below).
# Option B: leave blank and create the default password on first launch via the login bootstrap screen.
# Obtain SHA-256 value via: echo -n 'ClearPassword' | shasum -a 256
# Login with username admin and the configured password.
DEFAULT_PASSWORD_SHA256=

# Cisco AI Defense API Key
CISCO_AI_DEFENSE_API_KEY=

# LLM API KEYS
OPENAI_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=
CLAUDE_API_KEY=
 
# AWS IAM credentials to access LLMs in Bedrock
AWS_REGION=
AWS_ACCESS_KEY=
AWS_SECRET_KEY=
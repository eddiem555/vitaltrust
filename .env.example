# Vital Trust environment variables (used by DeployVitalTrust.sh via Docker --env-file)
# Do NOT wrap values in quotes — Docker passes quotes literally and quotes will break auth/API keys

# Local user default password — SHA-256 hex digest (no salt).
# Obtain SHA-256 value via: echo -n 'ClearPassword' | shasum -a 256
# Login with username admin and the configured password.
DEFAULT_PASSWORD_SHA256=

# Cisco Duo OIDC (OpenID Connect) Configuration
DUO_ISSUER_URL=
DUO_CLIENT_ID=
DUO_CLIENT_SECRET=

# LLM API KEYS (Use for independent LLM access)
OPENAI_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=
CLAUDE_API_KEY=
 
# AWS IAM credentials (Use for AWS Bedrock access)
AWS_REGION=
AWS_ACCESS_KEY=
AWS_SECRET_KEY=

# Cisco AI Defense API Key (Use for AI Defense LLM security controls)
# Obtain API key from https://us.api.inspect.aidefense.security.cisco.com
CISCO_AI_DEFENSE_API_KEY=

# MCP server (Streamable HTTP at /mcp — Cisco Secure Access AI Resources)
# Set MCP_ENABLED=false to disable the /mcp endpoint
MCP_ENABLED=true
# Default VitalTrust user context when external MCP clients have no identity headers (lab / connector probe)
MCP_DEMO_USER_ID=doctor1
MCP_DEMO_ROLE=doctor